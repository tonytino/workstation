; ~/.gitconfig — managed by chezmoi (repo: tonytino/workstation)
; Templated: name + email are pulled from 1Password at apply time.
; The vault name is the `opVault` data var (prompted once at `chezmoi init`,
; defaults to `Personal`). See `op item get "Git Identity" --vault "$opVault"`.

[user]
  name = {{ onepasswordRead (printf "op://%s/Git Identity/name" .opVault) }}
  email = {{ onepasswordRead (printf "op://%s/Git Identity/email" .opVault) }}

[alias]
  a = add
  amend = commit --amend --no-edit
  br = branch
  ci = commit
  co = checkout
  df = diff
  dff = diff --name-status
  dfl = diff HEAD^
  dfs = diff --staged
  last = log -1 HEAD
  lg = log -10 --pretty=format:'%h - %an, %ar : %s'
  new = checkout -b
  rename = branch -m
  st = status
  undo = reset HEAD~
  unstage = reset HEAD --

[color "status"]
  added = green
  changed = yellow
  untracked = cyan

[core]
  excludesfile = ~/.gitignore_global
  editor = nvim
  pager = delta

[init]
  defaultBranch = main

[push]
  default = current
  autoSetupRemote = true

[pull]
  rebase = true

[fetch]
  prune = true

[rebase]
  autoStash = true

[diff]
  colorMoved = default

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  line-numbers = true
  syntax-theme = GitHub

; Machine-local overrides (NOT managed by chezmoi). Create ~/.gitconfig.local
; on a per-machine basis — e.g. a work email scoped to work repos:
;   [includeIf "gitdir:~/work/"]
;     path = ~/.gitconfig-work
; Anything here wins over the settings above because the include is last.
[include]
  path = ~/.gitconfig.local
